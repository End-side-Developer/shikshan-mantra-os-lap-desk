#!/bin/sh
# auto/build — invoke live-build. Called by scripts/build/build-iso.sh.
# PROTECTED: see CODEOWNERS (@shikshan/platform @shikshan/security).

set -eu

if [ "$(id -u)" -ne 0 ]; then
    echo "auto/build must run as root inside the build container" >&2
    exit 1
fi

# Clean state from previous runs that may have failed mid-way
lb clean --purge 2>/dev/null || true

# Reconfigure (idempotent; auto/config is the source of truth)
./auto/config "${@}"

# Build — call stages directly. `lb build` would defer back to this auto/build
# script (live-build auto-detects auto/{config,build,clean}) causing infinite recursion.
lb bootstrap "${@}"
lb chroot "${@}"
lb binary "${@}"

# Move resulting ISO to artifacts/ for downstream verification.
# Live-build's filename varies by version and config:
#   modern (>= 2020):    live-image-${ARCH}.hybrid.iso  (current trixie)
#   intermediate:        binary.hybrid.iso  /  binary.iso
mkdir -p artifacts/
ARCH_FOR_ISO="$(dpkg --print-architecture 2>/dev/null || echo amd64)"
for candidate in \
    "live-image-${ARCH_FOR_ISO}.hybrid.iso" \
    "live-image-${ARCH_FOR_ISO}.iso" \
    "binary.hybrid.iso" \
    "binary.iso" ; do
    if [ -f "$candidate" ]; then
        mv "$candidate" artifacts/shikshan.iso
        SRC_NAME="$candidate"
        break
    fi
done
if [ ! -f "artifacts/shikshan.iso" ]; then
    echo "auto/build: no ISO produced (looked for live-image-*.hybrid.iso, binary*.iso)" >&2
    ls -la *.iso 2>&1 || true
    exit 2
fi
echo "auto/build: found ISO at ${SRC_NAME:-unknown}, moved to artifacts/shikshan.iso"

# Hashes
sha256sum artifacts/shikshan.iso | tee artifacts/shikshan.iso.sha256
sha512sum artifacts/shikshan.iso | tee artifacts/shikshan.iso.sha512

echo "auto/build: complete -> artifacts/shikshan.iso"
