# live-build build artifacts
# `lb config` writes these stage files + drops template hooks into config/; they are generated, not source.
/config/binary
/config/bootstrap
/config/chroot
/config/common
/config/source
/config/package-lists/live.list.chroot
/config/hooks/live/0010-disable-kexec-tools.hook.chroot
/config/hooks/live/0050-disable-sysvinit-tmpfs.hook.chroot
/config/hooks/normal/1000-create-mtab-symlink.hook.chroot
/config/hooks/normal/1010-enable-cryptsetup.hook.chroot
/config/hooks/normal/1020-create-locales-files.hook.chroot
/config/hooks/normal/5000-update-apt-file-cache.hook.chroot
/config/hooks/normal/5010-update-apt-xapian-index.hook.chroot
/config/hooks/normal/5020-update-glx-alternative.hook.chroot
/config/hooks/normal/5030-update-plocate-database.hook.chroot
/config/hooks/normal/5040-update-nvidia-alternative.hook.chroot
/config/hooks/normal/5050-dracut.hook.chroot
/config/hooks/normal/8000-remove-adjtime-configuration.hook.chroot
/config/hooks/normal/8010-remove-backup-files.hook.chroot
/config/hooks/normal/8020-remove-dbus-machine-id.hook.chroot
/config/hooks/normal/8030-truncate-log-files.hook.chroot
/config/hooks/normal/8040-remove-mdadm-configuration.hook.chroot
/config/hooks/normal/8050-remove-openssh-server-host-keys.hook.chroot
/config/hooks/normal/8060-remove-systemd-machine-id.hook.chroot
/config/hooks/normal/8070-remove-temporary-files.hook.chroot
/config/hooks/normal/8080-reproducible-glibc.hook.chroot
/config/hooks/normal/8090-remove-ssl-cert-snakeoil.hook.chroot
/config/hooks/normal/8100-remove-udev-persistent-cd-rules.hook.chroot
/config/hooks/normal/8110-remove-udev-persistent-net-rules.hook.chroot
/config/hooks/normal/9000-remove-gnome-icon-cache.hook.chroot
/config/hooks/normal/9010-remove-python-pyc.hook.chroot
/config/hooks/normal/9020-remove-man-cache.hook.chroot
binary/
binary.iso
binary.hybrid.iso
binary.img
binary.contents
binary.packages
binary.list
binary*.zsync
binary*.zsync2
chroot/
chroot.packages.install
chroot.packages.live
chroot.files
cache/
local/
.stage/
.build/
auto/.lb-config

# Build outputs
artifacts/
out/
dist/
build/

# Releases (output bundle) — see docs/adr/0006-release-artifact-layout.md
releases/*
!releases/README.md
!releases/.gitkeep

# SBOM / scan artifacts (kept in artifacts/, not in repo root)
*.cdx.json
*.cdx.xml
*.sbom.json
*.spdx.json
*.intoto.jsonl
*.sig
*.cert

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Node (used by commitlint, markdownlint, etc.)
node_modules/
package-lock.json
yarn.lock
.npm/

# Editor / OS
.idea/
.vscode/
!.vscode/extensions.json
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Claude Code per-developer overrides
.claude/settings.local.json
.claude/.session/
.claude/.cache/
.claude/scheduled_tasks.lock

# Pre-commit
.pre-commit-cache/

# Secrets (must never be committed; gitleaks also blocks)
*.pem
*.key
*.crt
!config/archives/*.key.chroot
!config/archives/*.key.binary
.env
.env.*
!.env.example
secrets/
credentials/

# QEMU / VM test artifacts
*.qcow2
*.vmdk
tests/qemu/.cache/
tests/qemu/logs/

# Vidyarthi content staged into the overlay by scripts/build/sync-ui-to-iso.sh
# (SMO-0615). Canonical source lives under modules/; these are materialised at
# build time and must not be committed.
/config/includes.chroot/usr/share/shikshan/modules/
/config/includes.chroot/usr/share/shikshan/catalogs/

# Vendored upstream sources (per docs/adr/0003-vendor-strategy.md)
# Clones are materialised locally by scripts/dev/vendor-sync.py; only the
# manifest, README, and .gitkeep are tracked.
vendor/*
!vendor/MANIFEST.yml
!vendor/README.md
!vendor/.gitkeep
