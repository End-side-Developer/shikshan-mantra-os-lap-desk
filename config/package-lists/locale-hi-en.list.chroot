# config/package-lists/locale-hi-en.list.chroot
# Hindi + English locale + IME for Hindi typing.
#
# ADR-0007 (live-build config flags) — 2 GB RAM profile: --apt-recommends false
# Chroot footprint target: combined lists <= 1100 MB installed size

locales
locales-all
keyboard-configuration

# Input method (Devanagari typing — covers Hindi + Marathi via ibus-m17n)
ibus
ibus-m17n
m17n-db
