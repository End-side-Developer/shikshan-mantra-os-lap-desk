{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shikshan-mantra-os/modules/catalogs/schemas/catalog.schema.json",
  "title": "Shikshan Mantra OS Catalog Manifest",
  "description": "Signed registry of modules. Per PLAN.md 'Public Interfaces' + docs/architecture/module-system.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalog_id", "publisher", "trust_level", "modules"],
  "properties": {
    "catalog_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*/[a-z][a-z0-9-]*$",
      "description": "publisher/catalog-name, e.g., shikshan/official"
    },
    "publisher": {
      "type": "string",
      "minLength": 2
    },
    "trust_level": {
      "type": "string",
      "enum": ["official", "verified-community", "community", "experimental"]
    },
    "update_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Public URL where the catalog is published (catalog publisher serves a manifest; null = local-only)"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "modules": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "checksum"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.]+)?$" },
          "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "path": {
            "type": "string",
            "description": "Path to the module's manifest.yml relative to repo root (for in-repo catalogs)"
          }
        }
      },
      "uniqueItems": true
    },
    "signature": {
      "type": ["string", "null"],
      "description": "Cosign signature (set by release workflow; null in dev)"
    }
  }
}
