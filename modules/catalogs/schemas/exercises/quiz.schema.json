{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shikshan-mantra-os/modules/catalogs/schemas/exercises/quiz.schema.json",
  "title": "Shikshan Mantra OS — Quiz Exercise Spec",
  "description": "Schema for a declarative quiz exercise (MCQ or fill-blank). content_type=quiz, no engine subprocess needed. SMO-0512.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "prompt", "kind", "locale"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "hi"],
      "properties": {
        "en": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "hi": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "kind": {
      "type": "string",
      "enum": ["mcq", "fill-blank", "true-false"],
      "description": "mcq = multiple-choice single-answer, fill-blank = short text match, true-false = boolean choice"
    },
    "choices": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]{1,8}$" },
          "text": {
            "type": "object",
            "additionalProperties": false,
            "required": ["en", "hi"],
            "properties": {
              "en": { "type": "string", "minLength": 1 },
              "hi": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "description": "Required for kind=mcq. The correct_answer must match one choice id."
    },
    "correct_answer": {
      "description": "For mcq: choice id string. For fill-blank: string or array of accepted strings (case-insensitive match). For true-false: boolean."
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "hi"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "hi": { "type": "string", "minLength": 1 }
      },
      "description": "Shown after the learner submits, explaining the correct answer."
    },
    "locale": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["en", "hi"] },
      "uniqueItems": true
    }
  }
}
