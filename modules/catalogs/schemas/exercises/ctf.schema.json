{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shikshan-mantra-os/modules/catalogs/schemas/exercises/ctf.schema.json",
  "title": "Shikshan Mantra OS — CTF Exercise Spec (skeleton)",
  "description": "Schema for a capture-the-flag security exercise (sub_engine=ctf). Skeleton — engine (rootless Podman container) arrives post-MVP. Policy-gated: not available under safety_mode=strict. SMO-0515.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "prompt", "flag_format", "scenario", "locale"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "hi"],
      "properties": {
        "en": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "hi": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "flag_format": {
      "type": "string",
      "description": "Regex pattern the submitted flag must match (e.g. '^SMO\\{[A-Za-z0-9_]+\\}$')"
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_image", "objective"],
      "properties": {
        "container_image": {
          "type": "string",
          "description": "OCI image reference. Must be pre-pulled and signed in the module bundle (offline-first)."
        },
        "objective": {
          "type": "object",
          "additionalProperties": false,
          "required": ["en", "hi"],
          "properties": {
            "en": { "type": "string", "minLength": 1 },
            "hi": { "type": "string", "minLength": 1 }
          }
        },
        "exposed_ports": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "description": "Container ports exposed to the sandbox network namespace (not the host)."
        }
      }
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["en", "hi"],
        "properties": {
          "en": { "type": "string", "minLength": 1 },
          "hi": { "type": "string", "minLength": 1 }
        }
      }
    },
    "locale": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["en", "hi"] },
      "uniqueItems": true
    }
  }
}
