{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shikshan-mantra-os/modules/catalogs/schemas/exercises/web.schema.json",
  "title": "Shikshan Mantra OS — Web Exercise Spec (skeleton)",
  "description": "Schema for a web sandbox exercise (sub_engine=web, HTML/CSS/JS). Skeleton — engine implementation arrives in SMO-0600+. SMO-0514.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "prompt", "starter", "assertions", "locale"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "hi"],
      "properties": {
        "en": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "hi": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "starter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "html": { "type": "string", "default": "" },
        "css":  { "type": "string", "default": "" },
        "js":   { "type": "string", "default": "" }
      },
      "description": "Pre-filled HTML/CSS/JS panes. Any or all may be empty strings."
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "dom_contains_selector",
              "dom_element_text",
              "dom_element_count",
              "no_js_error",
              "css_property"
            ]
          },
          "selector": { "type": "string" },
          "expected": {},
          "message": {
            "type": "object",
            "additionalProperties": false,
            "required": ["en", "hi"],
            "properties": {
              "en": { "type": "string", "minLength": 1 },
              "hi": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["en", "hi"],
        "properties": {
          "en": { "type": "string", "minLength": 1 },
          "hi": { "type": "string", "minLength": 1 }
        }
      }
    },
    "locale": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["en", "hi"] },
      "uniqueItems": true
    }
  }
}
