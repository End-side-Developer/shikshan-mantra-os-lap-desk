{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shikshan-mantra-os/modules/catalogs/schemas/module.schema.json",
  "title": "Shikshan Mantra OS Module Manifest",
  "description": "Canonical schema for a single learning module's manifest.yml. Per PLAN.md 'Public Interfaces' + docs/architecture/module-system.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "version", "title", "language", "age_band", "difficulty",
    "prerequisites", "outcomes", "content_type", "entrypoint",
    "required_apps", "unlock_rules", "license", "checksum"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$",
      "description": "kebab-case unique identifier within the catalog"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.]+)?$",
      "description": "SemVer 2.0"
    },
    "title": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "hi"],
      "properties": {
        "en": { "type": "string", "minLength": 1, "maxLength": 100 },
        "hi": { "type": "string", "minLength": 1, "maxLength": 100 }
      },
      "description": "Hindi + English parity required (AGENTS.md §13)"
    },
    "description": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "hi"],
      "properties": {
        "en": { "type": "string" },
        "hi": { "type": "string" }
      }
    },
    "language": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["en", "hi"] },
      "uniqueItems": true,
      "description": "Languages the module's content is provided in"
    },
    "age_band": {
      "type": "string",
      "enum": ["5-8", "9-12", "13-15", "16-18", "18+"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
      "uniqueItems": true
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["en", "hi"],
        "properties": {
          "en": { "type": "string", "minLength": 1 },
          "hi": { "type": "string", "minLength": 1 }
        }
      }
    },
    "content_type": {
      "type": "string",
      "enum": [
        "html", "pdf", "video", "webxr", "blockly", "python", "jupyter",
        "interactive-runner",
        "quiz"
      ],
      "description": "interactive-runner and quiz are Vidyarthi engine types (ADR-0011, SMO-0510)"
    },
    "sub_engine": {
      "type": "string",
      "enum": ["sql", "web", "code", "ctf", "quiz"],
      "description": "Required when content_type is interactive-runner. Selects the Vidyarthi engine subprocess."
    },
    "exercise_spec": {
      "type": "object",
      "description": "Engine-specific exercise specification. Shape validated against modules/catalogs/schemas/exercises/<sub_engine>.schema.json at module install time."
    },
    "entrypoint": {
      "type": "string",
      "description": "Relative path inside the module bundle (e.g., index.html, main.py). For interactive-runner modules this is typically exercises/ directory."
    },
    "required_apps": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.+-]*$" },
      "description": "Debian package names required at runtime"
    },
    "unlock_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": { "type": "string", "enum": ["completion", "score", "age_min", "free"] },
          "of": { "type": "string", "description": "module id (for completion/score kinds)" },
          "min_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "age_min": { "type": "integer", "minimum": 5 }
        }
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX expression (e.g., CC-BY-SA-4.0, MIT)"
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 of the canonical content tree manifest"
    },
    "signature": {
      "type": ["string", "null"],
      "description": "Cosign signature (set by release workflow; null in dev)"
    }
  }
}
