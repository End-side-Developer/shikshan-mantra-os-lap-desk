# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,md}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{py}]
indent_size = 4
max_line_length = 100

# Debian package lists / pref files
[*.list*]
indent_size = 2

[*.pref*]
indent_size = 2
